# Server Configuration
NODE_ENV=development
PORT=4000

# Database
# Replace with your actual MongoDB connection string locally
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/smart-dashboard

# Authentication
# Must be at least 32 characters long
JWT_SECRET=your_32_character_super_secret_string_here
JWT_EXPIRES_IN=1d

# Cookie & Security Setup
# Set to true in production for HTTPS
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:5173
