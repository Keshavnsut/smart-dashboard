# Used by docker-compose.prod.yml on a server.

# Optional (only needed if you push/pull from a registry)
DOCKER_REGISTRY=docker.io
DOCKER_REPO=keshavnsut/smart-dashboard

# Backend
MONGO_URI=mongodb://mongo:27017/smart_leads_dashboard
JWT_SECRET=change-me-change-me-change-me-change-me
JWT_EXPIRES_IN=1d

# If you do NOT have HTTPS yet, set this to false so auth works over HTTP.
# Recommended: keep true and use HTTPS.
COOKIE_SECURE=true

# Only relevant if you call the backend cross-origin.
# With the provided frontend nginx reverse-proxy (/api -> backend), same-origin is recommended.
CORS_ORIGIN=http://localhost
